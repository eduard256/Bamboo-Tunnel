# Bamboo Tunnel Client Configuration

# Server URL with HTTPS (required)
BAMBOO_SERVER_URL=https://bamboo.example.com

# Shared secret token, must match server (required)
BAMBOO_TOKEN=change_me_to_a_long_random_string

# Tunnel path prefix (must match server expectation)
BAMBOO_TUNNEL_PATH=/odr/v1/call

# Session rotation settings
BAMBOO_SESSION_MIN=5m
BAMBOO_SESSION_MAX=20m
BAMBOO_SESSION_OVERLAP=30s

# Log level: debug, info, warn, error
BAMBOO_LOG_LEVEL=info
