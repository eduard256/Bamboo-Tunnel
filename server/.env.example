# Bamboo Tunnel Server Configuration

# Shared secret token for tunnel authentication (required)
BAMBOO_TOKEN=change_me_to_a_long_random_string

# HTTP listen port (Caddy reverse-proxies to this)
BAMBOO_PORT=8080

# Path to static web files directory
BAMBOO_WEB_DIR=./web

# Log level: debug, info, warn, error
BAMBOO_LOG_LEVEL=info
